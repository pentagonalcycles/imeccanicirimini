---
import type { Locale } from '../lib/i18n';
import { useTranslations } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="gallery" class="section-padding">
  <div class="container-custom">
    <h2 class="text-center mb-4">{t.gallery.heading}</h2>

    <div class="text-center mb-10">
      <a
        href="https://www.instagram.com/imeccanicirimini/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-accent font-semibold text-lg hover:underline"
      >
        {t.gallery.handle}
      </a>
      <p class="mt-4 text-text-light max-w-xl mx-auto" set:html={t.gallery.hashtag} />
    </div>

    <div class="elfsight-app-a4cf00c9-5a0c-4293-8b02-208ba5325633"></div>
  </div>
</section>

<script src="https://apps.elfsight.com/p/platform.js" defer></script>
