---
import type { Locale } from '../lib/i18n';
import { useTranslations } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const reviews: { name: string; rating: number; text: string }[] = locale === 'it'
  ? [
      {
        name: 'Marco R.',
        rating: 5,
        text: 'Personale competente e cordiale. Ho portato la mia Brompton per la revisione annuale e me l\'hanno rimessa come nuova. Consigliatissimo!',
      },
      {
        name: 'Elena S.',
        rating: 5,
        text: 'Ho comprato una bici Primabici per mio figlio e sono rimasta molto soddisfatta. Ottima assistenza e consigli personalizzati.',
      },
      {
        name: 'Luca P.',
        rating: 4,
        text: 'Riparazione veloce e professionale. Mi hanno anche prestato una bici di cortesia mentre aspettavo. Tornerò sicuramente!',
      },
      {
        name: 'Giulia M.',
        rating: 5,
        text: 'Negozio fantastico nel cuore di Rimini. Ho trovato tutto il necessario per il bikepacking: borse Ortlieb e accessori di qualità.',
      },
    ]
  : [
      {
        name: 'Marco R.',
        rating: 5,
        text: 'Competent and friendly staff. I brought my Brompton in for the annual service and they made it like new. Highly recommended!',
      },
      {
        name: 'Elena S.',
        rating: 5,
        text: 'I bought a Primabici bike for my son and was very satisfied. Great service and personalized advice.',
      },
      {
        name: 'Luca P.',
        rating: 4,
        text: 'Fast and professional repair. They even lent me a courtesy bike while I waited. Will definitely be back!',
      },
      {
        name: 'Giulia M.',
        rating: 5,
        text: 'Fantastic shop in the heart of Rimini. Found everything I needed for bikepacking: Ortlieb bags and quality accessories.',
      },
    ];
---

<section id="reviews" class="section-padding" style="background-color: var(--color-secondary);">
  <div class="container-custom">
    <div class="text-center mb-12">
      <h2 class="mb-4">{t.reviews.heading}</h2>
      <p class="text-text-light">{t.reviews.subtitle}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {reviews.map((review) => (
        <div class="feature-card">
          <div class="flex gap-1 mb-4">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg
                class={`w-5 h-5 ${i < review.rating ? 'text-accent' : 'text-gray-300'}`}
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-text-light mb-4">{review.text}</p>
          <p class="font-semibold text-sm">{review.name}</p>
        </div>
      ))}
    </div>
  </div>
</section>
