---
import type { Locale } from '../lib/i18n';
import { useTranslations, getLocalizedPath } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const currentYear = new Date().getFullYear();
const copyrightText = t.footer.copyright.replace('{year}', String(currentYear));
---

<footer class="py-12" style="background-color: var(--color-dark);">
  <div class="container-custom">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-white">
      <div>
        <h3 class="text-lg font-semibold mb-4 text-white">{t.footer.company}</h3>
        <p class="text-sm opacity-80 leading-relaxed">
          {t.footer.address}<br />
          {t.footer.vat}
        </p>
      </div>

      <div class="flex flex-col items-center">
        <div class="flex gap-3 mb-4">
          <a
            href="https://www.facebook.com/imeccanicirimini-260312807351020/"
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
            aria-label="Facebook"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
          </a>
          <a
            href="https://www.instagram.com/imeccanicirimini/"
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
            aria-label="Instagram"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
            </svg>
          </a>
        </div>
      </div>

      <div class="flex flex-col md:items-end gap-3">
        <a href={getLocalizedPath('/privacy', locale)} class="text-sm text-white/80 hover:text-accent transition-colors">
          {t.footer.privacy}
        </a>
        <a href={getLocalizedPath('/accessibility', locale)} class="text-sm text-white/80 hover:text-accent transition-colors">
          {t.footer.accessibility}
        </a>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-white/10 text-center">
      <p class="text-sm text-white/60">{copyrightText}</p>
    </div>
  </div>
</footer>
